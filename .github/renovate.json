{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/Vancouver",
  "schedule": ["every weekend"],
  "labels": ["renovate"],
  "assignees": ["StanleyXie"],
  "ignoreDeps": [
    "upbound/provider-family-aws",
    "upbound/provider-family-gcp",
    "upbound/provider-family-azure",
    "upbound/provider-terraform"
  ],
  "packageRules": [
    {
      "description": "Platform core components — batch weekly, no automerge",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": [
        "argo-cd",
        "cilium",
        "kyverno",
        "kyverno-policies",
        "crossplane"
      ],
      "groupName": "platform-core",
      "automerge": false,
      "labels": ["renovate", "platform-core"]
    },
    {
      "description": "Service workloads — automerge all updates",
      "matchManagers": ["custom.regex", "helm-values"],
      "matchPackageNames": ["searxng", "searxng/searxng"],
      "automerge": true,
      "automergeType": "pr",
      "labels": ["renovate", "service"]
    },
    {
      "description": "GitHub Actions — pin digests, no automerge",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "pinDigests": true,
      "automerge": false,
      "labels": ["renovate", "ci-tooling"]
    },
    {
      "description": "CI tool binaries — automerge all",
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["yannh/kubeconform", "kyverno/kyverno"],
      "automerge": true,
      "labels": ["renovate", "ci-tooling"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^apps/argocd\\.yaml$"],
      "matchStrings": ["targetRevision:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "argo-cd",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://argoproj.github.io/argo-helm"
    },
    {
      "customType": "regex",
      "fileMatch": ["^apps/cilium\\.yaml$"],
      "matchStrings": ["targetRevision:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "cilium",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://helm.cilium.io"
    },
    {
      "customType": "regex",
      "fileMatch": ["^apps/kyverno\\.yaml$"],
      "matchStrings": ["targetRevision:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "kyverno",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://kyverno.github.io/kyverno"
    },
    {
      "customType": "regex",
      "fileMatch": ["^apps/kyverno-policies\\.yaml$"],
      "matchStrings": ["targetRevision:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "kyverno-policies",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://kyverno.github.io/kyverno"
    },
    {
      "customType": "regex",
      "fileMatch": ["^apps/crossplane\\.yaml$"],
      "matchStrings": ["targetRevision:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "crossplane",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://charts.crossplane.io/stable"
    },
    {
      "customType": "regex",
      "fileMatch": ["^apps/searxng\\.yaml$"],
      "matchStrings": ["targetRevision:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "searxng",
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://unknowniq.github.io/helm-charts"
    },
    {
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.+\\.yml$"],
      "matchStrings": [
        "kubeconform/releases/download/(?<currentValue>v[\\d.]+)/kubeconform"
      ],
      "depNameTemplate": "yannh/kubeconform",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["\\.github/workflows/.+\\.yml$"],
      "matchStrings": [
        "kyverno/releases/download/(?<currentValue>v[\\d.]+)/kyverno-cli"
      ],
      "depNameTemplate": "kyverno/kyverno",
      "datasourceTemplate": "github-releases"
    }
  ]
}
